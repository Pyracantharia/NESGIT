generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  username  String    @unique
  password  String
  color     String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}


